---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const latestPosts = posts.slice(0, 5);
---

<BaseLayout title="我的学习博客" description="记录学习历程，分享心得体会，展示个人作品">
  <div style="text-align: center; padding: 3rem 0 2rem;">
    <h1 style="font-size: 2.5rem; margin-bottom: 1rem;">👋 你好，我是学习者</h1>
    <p style="font-size: 1.15rem; color: var(--color-muted); max-width: 600px; margin: 0 auto 2rem;">
      这里记录我的学习历程、心得体会和项目作品。希望这些文字能帮到正在学习路上的你。
    </p>
    <a href="/blog" style="display: inline-block; background: var(--color-primary); color: white; padding: 0.75rem 2rem; border-radius: 8px; font-weight: 500; text-decoration: none;">
      📖 浏览全部文章
    </a>
  </div>

  <hr style="margin: 3rem 0;" />

  <h2>📝 最新文章</h2>
  {latestPosts.length > 0 ? (
    <div style="display: flex; flex-direction: column; gap: 1rem; margin-top: 1.5rem;">
      {latestPosts.map((post) => (
        <a href={`/blog/${post.id}/`} class="card" style="text-decoration: none; color: inherit; display: block;">
          <div style="display: flex; justify-content: space-between; align-items: flex-start; flex-wrap: wrap; gap: 0.5rem;">
            <h3 style="margin: 0; font-size: 1.25rem; color: var(--color-primary);">{post.data.title}</h3>
            <time style="font-size: 0.875rem; color: var(--color-muted); white-space: nowrap;" datetime={post.data.pubDate.toISOString()}>
              {post.data.pubDate.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}
            </time>
          </div>
          <p style="margin: 0.5rem 0 0; color: var(--color-muted); font-size: 0.95rem;">{post.data.description}</p>
          {post.data.tags && (
            <div style="margin-top: 0.75rem;">
              {post.data.tags.map((tag) => (
                <span class="tag">{tag}</span>
              ))}
            </div>
          )}
        </a>
      ))}
    </div>
  ) : (
    <p style="text-align: center; color: var(--color-muted); padding: 2rem 0;">暂无文章，敬请期待！</p>
  )}
</BaseLayout>
